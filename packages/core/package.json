    "@types/webxr": "*",
    "@vueuse/core": "^10.0.0",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "vue": ">=3.3",
    "three": ">=0.156"
  }
}
