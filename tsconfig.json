{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es2019", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "jsx": "preserve",
    "pretty": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "removeComments": false,
    "emitDeclarationOnly": true,
    "resolveJsonModule": true,
    "noImplicitThis": false,
    "baseUrl": "./",
    "paths": {
      "@bluera/vue-threejs": ["packages/core/src/index.ts"],
      "@bluera/vue-threejs/*": ["packages/core/src/*"],
      "@bluera/vue-threejs-test-renderer": ["packages/test-renderer/src/index.tsx"],
      "@bluera/vue-threejs-test-renderer/*": ["packages/test-renderer/src/*"]
    },
    "types": ["vitest/globals", "node", "offscreencanvas"]
  },
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "dist"]
}
